{
  "name": "@futurekode/stablepay-react",
  "version": "0.8.3",
  "description": "Headless React wrapper for USDC payments on Solana",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "buffer": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FutureKode/stablepay-react.git"
  },
  "homepage": "https://github.com/FutureKode/stablepay-react#readme",
  "bugs": {
    "url": "https://github.com/FutureKode/stablepay-react/issues"
  },
  "license": "MIT",
  "keywords": [
    "react",
    "solana",
    "usdc",
    "payments",
    "wallet",
    "crypto"
  ]
}
